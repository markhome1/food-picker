# 复制为 .env 后填写。切勿将含真实 Key 的 .env 提交到公开仓库。

# 仅填「Web服务」Key（地理编码 / 静态图等）。H5 地图用 frontend/src/manifest.json 里的 JS API Key，二者分开配置即可。
# 若报 USERKEY_PLAT_NOMATCH，说明把 JS 专用 Key 误填到了此处。
AMAP_KEY=

# 截图识别店名（OCR Space 免费 key）：https://ocr.space/ocrapi
# OCR_SPACE_API_KEY=

# 本地开发可不填，默认使用 backend/data/food_picker.db
# 生产环境建议使用托管 Postgres（Neon / Vercel Postgres）
# DATABASE_URL=postgresql://user:password@host/database?sslmode=require&channel_binding=require
